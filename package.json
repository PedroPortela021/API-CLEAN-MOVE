{
  "name": "api-clean-move",
  "version": "1.0.0",
  "main": "dist/infra/main.js",
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "bash ./scripts/dev.sh",
    "docker:up": "docker compose up -d",
    "docker:stop": "docker compose stop",
    "lint": "eslint . --cache --cache-location .eslintcache",
    "lint:fix": "npm run lint -- --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "check:all": "npm run build && npm run lint && npm run format && npm run typecheck && npm run test",
    "prisma:generate": "prisma generate",
    "start": "node dist/infra/main.js",
    "start:dev": "ts-node src/infra/main.ts",
    "test": "vitest run",
    "test:unit": "vitest run src",
    "test:infra": "vitest run test/infra",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PedroPortela021/API-CLEAN-MOVE.git"
  },
